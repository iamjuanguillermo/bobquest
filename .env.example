BOBQUEST_PUBLIC_DEMO_MODE=true
BOBQUEST_ALLOWED_REPOS=owner/repo1,owner/repo2
BOBQUEST_MAX_CONCURRENT_RUNS=1
BOBQUEST_MAX_RUNS_TOTAL=10
BOBQUEST_MAX_RUNS_PER_HOUR=2
BOBQUEST_MAX_EVALUATIONS_PER_RUN=5
BOBQUEST_MAX_LOCALIZATIONS_PER_RUN=2
BOBQUEST_RUNTIME_DISABLED=false

BOBQUEST_OPTIONAL_LLM_ENABLED=false
BOBQUEST_OPTIONAL_LLM_PROVIDER=watsonx
BOBQUEST_OPTIONAL_LLM_JSON_RECOVERY=false
BOBQUEST_OPTIONAL_LLM_LOCALIZATION=false

WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-2b-instruct
WATSONX_MAX_OUTPUT_TOKENS=2048
WATSONX_TEMPERATURE=0
WATSONX_TOP_P=1
BOBQUEST_OPTIONAL_LLM_TIMEOUT_MS=30000
BOBQUEST_OPTIONAL_LLM_MAX_RETRIES=1

# Slice 2 runtime API
PORT=8787
HOST=0.0.0.0
BOBQUEST_RUNTIME_DATA_DIR=data/runtime/runs
BOBQUEST_WORKSPACE_DIR=data/runtime/workspaces
BOBQUEST_CLONE_TIMEOUT_MS=60000
BOBQUEST_WORKSPACE_TTL_MS=21600000
BOBSHELL_COMMAND=
BOBSHELL_ARGS=
BOBSHELL_TIMEOUT_MS=180000
BOBSHELL_STATUS_ARGS=--version
BOBSHELL_STATUS_TIMEOUT_MS=5000
BOBSHELL_PREFLIGHT_CACHE_TTL_MS=60000
BOBSHELL_ANALYZE_ARGS=
BOBSHELL_EVALUATE_ARGS=
BOBSHELL_PROMPT_MODE=stdin
BOBSHELL_PROMPT_ARG=-p
VITE_BOBQUEST_RUNTIME_API_URL=http://localhost:8787
