# BobQuest real IBM Bob Shell Docker profile.
# This file is intentionally included for local smoke testing.
# Fill BOBSHELL_API_KEY before running real Bob Shell.

PORT=8787
HOST=0.0.0.0
NODE_ENV=production
BOBQUEST_PROJECT_ROOT=/workspace
VITE_BOBQUEST_RUNTIME_API_URL=http://localhost:8787

# Public demo safety. Use one or two small, real, public repos.
BOBQUEST_PUBLIC_DEMO_MODE=true
BOBQUEST_ALLOWED_REPOS=octocat/Hello-World
BOBQUEST_MAX_CONCURRENT_RUNS=1
BOBQUEST_MAX_RUNS_TOTAL=3
BOBQUEST_MAX_RUNS_PER_HOUR=1
BOBQUEST_MAX_EVALUATIONS_PER_RUN=1
BOBQUEST_MAX_LOCALIZATIONS_PER_RUN=0
BOBQUEST_RUNTIME_DISABLED=false

# Runtime storage inside the Docker volume.
BOBQUEST_RUNTIME_DATA_DIR=data/runtime/runs
BOBQUEST_WORKSPACE_DIR=data/runtime/workspaces
BOBQUEST_CLONE_TIMEOUT_MS=60000
BOBQUEST_WORKSPACE_TTL_MS=21600000

# IBM Bob Shell real CLI installed inside Dockerfile.real-bob.
BOBSHELL_COMMAND=bob

# Preflight must be lightweight and must not analyze a repo.
BOBSHELL_STATUS_ARGS=--version
BOBSHELL_STATUS_TIMEOUT_MS=10000
BOBSHELL_PREFLIGHT_CACHE_TTL_MS=60000

# Runtime commands. The adapter appends BOBSHELL_PROMPT_ARG and the generated prompt.
BOBSHELL_ARGS=
BOBSHELL_ANALYZE_ARGS=--auth-method,api-key
BOBSHELL_EVALUATE_ARGS=--auth-method,api-key
BOBSHELL_PROMPT_MODE=argument
BOBSHELL_PROMPT_ARG=-p
BOBSHELL_TIMEOUT_MS=180000
BOBSHELL_API_KEY=PASTE_YOUR_BOB_SHELL_API_KEY_HERE

# Optional IBM watsonx LLM remains disabled for the first real Bob Shell smoke.
BOBQUEST_OPTIONAL_LLM_ENABLED=false
BOBQUEST_OPTIONAL_LLM_PROVIDER=watsonx
BOBQUEST_OPTIONAL_LLM_JSON_RECOVERY=false
BOBQUEST_OPTIONAL_LLM_LOCALIZATION=false
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-2b-instruct
WATSONX_MAX_OUTPUT_TOKENS=2048
WATSONX_TEMPERATURE=0
WATSONX_TOP_P=1
BOBQUEST_OPTIONAL_LLM_TIMEOUT_MS=30000
BOBQUEST_OPTIONAL_LLM_MAX_RETRIES=1

# Real smoke runner. Status-only mode does not spend runtime analysis. Run-once requires ACK.
BOBQUEST_REAL_BOB_SMOKE_API_BASE_URL=http://127.0.0.1:8787
BOBQUEST_REAL_BOB_SMOKE_REPO_ID=octocat/Hello-World
BOBQUEST_REAL_BOB_SMOKE_ACK=
BOBQUEST_REAL_BOB_SMOKE_TIMEOUT_MS=300000
BOBQUEST_REAL_BOB_SMOKE_POLL_MS=1000
