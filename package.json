{
  "name": "bobquest-runtime-pivot",
  "version": "0.23.14-backend-b14",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "test": "python3 -u tests/run_all.py",
    "test:anti-drift": "python3 -u tests/anti_drift/test_no_obsolete_product_paths.py && python3 -u tests/anti_drift/test_ui_contracts.py && python3 -u tests/anti_drift/test_no_worker_runtime.py && python3 -u tests/anti_drift/test_no_product_endpoints.py",
    "test:contracts": "python3 -u tests/contracts/test_analysis_result_schema.py && python3 -u tests/contracts/test_run_state_schema.py && python3 -u tests/contracts/test_evaluation_contracts.py",
    "test:runtime": "python3 -u tests/runtime/test_slice1_runtime_boundary.py && python3 -u tests/runtime/test_runtime_api_structure.py && python3 -u tests/runtime/test_bob_shell_runtime_contract.py && python3 -u tests/runtime/test_repo_workspace_contract.py && python3 -u tests/runtime/test_runtime_state_store_contract.py && python3 -u tests/runtime/test_runtime_hard_failure_contract.py && python3 -u tests/runtime/test_slice4_objective_evaluation_contract.py && python3 -u tests/runtime/test_slice5_optional_ibm_llm_contract.py && python3 -u tests/runtime/test_b1_fake_bob_shell_e2e.py && python3 -u tests/runtime/test_b2_process_registry_contract.py && python3 -u tests/runtime/test_b2_process_registry_cancellation.py && python3 -u tests/runtime/test_b3_workspace_lifecycle_contract.py && python3 -u tests/runtime/test_b3_workspace_lifecycle_e2e.py && python3 -u tests/runtime/test_b4_open_evaluation_workspace_contract.py && python3 -u tests/runtime/test_b4_open_evaluation_workspace_e2e.py && python3 -u tests/runtime/test_b5_http_schemas_contract.py && python3 -u tests/runtime/test_b5_http_schemas_e2e.py && python3 -u tests/runtime/test_b6_analysis_semantic_validation_contract.py && python3 -u tests/runtime/test_b7_runtime_limits_contract.py && python3 -u tests/runtime/test_b7_runtime_limits_e2e.py && python3 -u tests/runtime/test_b8_observability_contract.py && python3 -u tests/runtime/test_b8_observability_e2e.py && python3 -u tests/runtime/test_b9_bob_preflight_contract.py && python3 -u tests/runtime/test_b9_bob_preflight_e2e.py",
    "test:ui": "python3 -u tests/ui/test_crew_dragon_shell.py && python3 -u tests/ui/test_runtime_flow_onboarding_surface.py && python3 -u tests/ui/test_slice4_interactions_surface.py && python3 -u tests/ui/test_slice5_localization_surface.py",
    "web:dev": "pnpm --filter bobquest-web dev",
    "web:build": "pnpm --filter bobquest-web build",
    "runtime:dev": "pnpm --filter bobquest-runtime-api dev",
    "runtime:start": "pnpm --filter bobquest-runtime-api start",
    "dev": "pnpm --parallel --filter bobquest-runtime-api --filter bobquest-web dev",
    "test:deploy": "python3 -u tests/deploy/test_docker_vps_hardening.py && python3 -u tests/deploy/test_real_bob_docker_runtime.py",
    "test:backend-e2e": "python3 -u tests/runtime/test_b1_fake_bob_shell_e2e.py",
    "test:backend-cancel": "python3 -u tests/runtime/test_b2_process_registry_contract.py && python3 -u tests/runtime/test_b2_process_registry_cancellation.py",
    "test:backend-workspace": "python3 -u tests/runtime/test_b3_workspace_lifecycle_contract.py && python3 -u tests/runtime/test_b3_workspace_lifecycle_e2e.py",
    "test:backend-evaluation-workspace": "python3 -u tests/runtime/test_b4_open_evaluation_workspace_contract.py && python3 -u tests/runtime/test_b4_open_evaluation_workspace_e2e.py",
    "test:backend-http-schemas": "python3 -u tests/runtime/test_b5_http_schemas_contract.py && python3 -u tests/runtime/test_b5_http_schemas_e2e.py",
    "test:backend-semantic-validation": "python3 -u tests/runtime/test_b6_analysis_semantic_validation_contract.py",
    "test:backend-limits": "python3 -u tests/runtime/test_b7_runtime_limits_contract.py && python3 -u tests/runtime/test_b7_runtime_limits_e2e.py",
    "test:backend-observability": "python3 -u tests/runtime/test_b8_observability_contract.py && python3 -u tests/runtime/test_b8_observability_e2e.py",
    "test:backend-bob-preflight": "python3 -u tests/runtime/test_b9_bob_preflight_contract.py && python3 -u tests/runtime/test_b9_bob_preflight_e2e.py",
    "test:backend-clone-safety": "python3 -u tests/runtime/test_repo_workspace_contract.py",
    "test:backend-command-profiles": "python3 -u tests/runtime/test_b10_bob_shell_command_profiles_contract.py && python3 -u tests/runtime/test_b10_bob_shell_command_profiles_e2e.py",
    "test:backend-real-bob-readiness": "python3 -u tests/runtime/test_b11_real_bob_readiness_pack.py",
    "smoke:real-bob:status": "node scripts/real-bob-runtime-smoke.mjs --status-only",
    "smoke:real-bob:run-once": "node scripts/real-bob-runtime-smoke.mjs --run-once",
    "test:backend-real-bob-cli-mode": "python3 -u tests/runtime/test_b12_real_bob_cli_prompt_mode_contract.py && python3 -u tests/runtime/test_b12_real_bob_cli_prompt_mode_e2e.py",
    "test:backend-real-bob-docker": "python3 -u tests/deploy/test_real_bob_docker_runtime.py",
    "test:backend-real-bob-docker-base": "python3 -u tests/deploy/test_real_bob_docker_runtime.py",
    "test:deploy-railway-two-services": "python3 -u tests/deploy/test_railway_two_service_deploy.py"
  }
}
